{
  "name": "statverdict",
  "version": "3.0.0",
  "description": "AI-powered loot analysis for ARPGs - Next-gen StatVerdict with enhanced performance and modern architecture",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && vercel --prod",
    "lint": "eslint . --ext .js",
    "format": "prettier --write \"**/*.{js,css,html,md}\""
  },
  "dependencies": {
    "@google-analytics/data": "^4.0.0",
    "@vercel/analytics": "^1.4.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "autoprefixer": "^10.4.16",
    "cssnano": "^6.0.2",
    "terser": "^5.26.0"
  },
  "keywords": [
    "diablo4",
    "arpg",
    "loot",
    "ai",
    "gaming",
    "performance",
    "accessibility"
  ],
  "author": "StatVerdict",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
